{
  "model": "3325A",
  "manufacturer": "HP",
  "category": "Synthesizer / Function Generator",
  "description": "HP 3325A synthesizer/function generator (1 uHz to 21 MHz). Command set documented from the HP 3325B manual, which shares the 3325A remote command set. Note: the ID?/IDN? identify queries were added on the 3325B and may not be supported on early 3325A units.",
  "source": "HP 3325B Operating Manual (command set shared with the 3325A)",
  "aliases": ["3325A", "3325B", "HP3325A", "HP3325B", "HP 3325A"],
  "termination": { "write": "\n", "read": "\n" },
  "identity": {
    "command": "ID?",
    "matchRegex": "3325",
    "description": "Short model identify (3325B). IDN? returns the long form. May not be supported on early 3325A units."
  },
  "statusModel": {
    "srqSupported": true,
    "serialPoll": { "clearsRqs": true },
    "enableMask": { "setCommand": "ESTB {mask}", "clearCommand": "ESTB 0", "maskFormat": "decimal" },
    "doneSupport": { "supported": false },
    "errorBit": "fail",
    "bits": {
      "error": 1,
      "stop": 2,
      "start": 4,
      "fail": 8,
      "rqs": 64
    },
    "operations": {
      "sweepComplete": { "arm": "RSW;SS;", "expectBit": "stop" }
    }
  },
  "commands": [
    {
      "name": "frequency",
      "mnemonic": "FR",
      "category": "Frequency",
      "description": "Sets or queries the output frequency. Interrogate with 'FR?' (or 'IFR').",
      "set": "FR <value> <unit>",
      "query": "FR?",
      "parameters": [
        { "name": "frequency", "units": ["HZ", "KH", "MH"], "range": "1 uHz to 21 MHz (sine); function dependent" }
      ],
      "examples": ["FR 1 MH", "FR 10000 HZ", "FR?"]
    },
    {
      "name": "function",
      "mnemonic": "FU",
      "category": "Waveform",
      "description": "Selects the output function: 0=DC only, 1=sine, 2=square, 3=triangle, 4=positive ramp, 5=negative ramp.",
      "set": "FU<code>",
      "query": "FU?",
      "parameters": [ { "name": "function", "range": "0-5" } ],
      "examples": ["FU1", "FU2", "FU?"]
    },
    {
      "name": "amplitude",
      "mnemonic": "AM",
      "category": "Amplitude",
      "description": "Sets or queries the output amplitude.",
      "set": "AM <value> <unit>",
      "query": "AM?",
      "parameters": [
        { "name": "amplitude", "units": ["VO", "MV", "VR", "MR", "DB"], "description": "VO=Vpp, MV=mVpp, VR=Vrms, MR=mVrms, DB=dBm" }
      ],
      "examples": ["AM 1.2 VO", "AM 0 DB", "AM?"]
    },
    {
      "name": "dc_offset",
      "mnemonic": "OF",
      "category": "Amplitude",
      "description": "Sets or queries the DC offset voltage.",
      "set": "OF <value> <unit>",
      "query": "OF?",
      "parameters": [ { "name": "offset", "units": ["VO", "MV"] } ],
      "examples": ["OF 1 VO", "OF?"]
    },
    {
      "name": "phase",
      "mnemonic": "PH",
      "category": "Phase",
      "description": "Sets or queries the phase of the output signal.",
      "set": "PH <value> DE",
      "query": "PH?",
      "parameters": [ { "name": "phase", "units": ["DE"], "description": "DE = degrees" } ],
      "examples": ["PH 90 DE", "PH?"]
    },
    {
      "name": "assign_zero_phase",
      "mnemonic": "AP",
      "category": "Phase",
      "description": "Assigns the current phase as the zero-phase reference.",
      "set": "AP",
      "examples": ["AP"]
    },
    {
      "name": "amplitude_calibration",
      "mnemonic": "AC",
      "category": "System",
      "description": "Performs an amplitude calibration cycle.",
      "set": "AC",
      "examples": ["AC"]
    },
    {
      "name": "sweep_start_frequency",
      "mnemonic": "ST",
      "category": "Sweep",
      "description": "Sets or queries the sweep start frequency.",
      "set": "ST <value> <unit>",
      "query": "ST?",
      "parameters": [ { "name": "frequency", "units": ["HZ", "KH", "MH"] } ],
      "examples": ["ST 1 KH", "ST?"]
    },
    {
      "name": "sweep_stop_frequency",
      "mnemonic": "SP",
      "category": "Sweep",
      "description": "Sets or queries the sweep stop frequency.",
      "set": "SP <value> <unit>",
      "query": "SP?",
      "parameters": [ { "name": "frequency", "units": ["HZ", "KH", "MH"] } ],
      "examples": ["SP 10 MH", "SP?"]
    },
    {
      "name": "sweep_time",
      "mnemonic": "TI",
      "category": "Sweep",
      "description": "Sets or queries the sweep time.",
      "set": "TI <value> SE",
      "query": "TI?",
      "parameters": [ { "name": "time", "units": ["SE", "MS"], "description": "SE = seconds" } ],
      "examples": ["TI 1 SE", "TI?"]
    },
    {
      "name": "start_single_sweep",
      "mnemonic": "SS",
      "category": "Sweep",
      "description": "Resets or starts a single sweep.",
      "set": "SS",
      "examples": ["SS"]
    },
    {
      "name": "start_continuous_sweep",
      "mnemonic": "SC",
      "category": "Sweep",
      "description": "Starts a continuous sweep.",
      "set": "SC",
      "examples": ["SC"]
    },
    {
      "name": "reset",
      "mnemonic": "RST",
      "category": "System",
      "description": "Resets the instrument to its preset state.",
      "set": "RST",
      "examples": ["RST"]
    },
    {
      "name": "self_test",
      "mnemonic": "TE",
      "category": "System",
      "description": "Initiates the instrument self test.",
      "set": "TE",
      "examples": ["TE"]
    },
    {
      "name": "error_query",
      "mnemonic": "ERR?",
      "category": "Status",
      "description": "Queries the error register (3-digit form). IER returns a 1-digit form.",
      "query": "ERR?",
      "examples": ["ERR?"]
    },
    {
      "name": "option_query",
      "mnemonic": "OPT?",
      "category": "System",
      "description": "Queries installed options.",
      "query": "OPT?",
      "examples": ["OPT?"]
    }
  ]
}
